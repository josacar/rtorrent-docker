# rtorrent-docker env vars
# Copy this file to .env and adjust.

# rtorrent SCGI port (default: 5000)
RT_SCGI_PORT=5000

# Global upload and download rate limits in KiB/s (0 = unlimited)
RT_UP_MAX_KB=0
RT_DOWN_MAX_KB=0

# Port range for BitTorrent peer connections
RT_PORT_RANGE=6881-6881

# Download directory inside the container (default: /data)
RT_DOWNLOAD_DIR=/data

# Session directory inside the container (default: /session)
RT_SESSION_DIR=/session